---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tagMap = new Map();
  
  posts.forEach((post) => {
    if (post.data.tags) {
      post.data.tags.forEach((tag) => {
        if (!tagMap.has(tag)) {
          tagMap.set(tag, []);
        }
        tagMap.get(tag).push(post);
      });
    }
  });
  
  return Array.from(tagMap.keys()).map((tag) => ({
    params: { tag },
    props: { tag, posts: tagMap.get(tag) }
  }));
}

const { tag, posts } = Astro.props;

function formatDate(dateString) {
  const date = new Date(dateString);
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  });
}
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <BaseHead title={`Tag: ${tag}`} />
  <style>
    main {
      max-width: 640px;
      margin: 0 auto;
      padding: 2rem 1.25rem 4rem;
    }

    .page-title {
      font-size: 1.75rem;
      font-weight: 700;
      margin: 0 0 0.5rem 0;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--text-primary);
    }

    .page-title::before {
      content: '';
      width: 4px;
      height: 1.75rem;
      background: linear-gradient(180deg, var(--accent), #8b5cf6);
      border-radius: 2px;
    }

    .page-subtitle {
      font-size: 0.95rem;
      color: var(--text-muted);
      margin: 0 0 2rem 0;
      padding-left: 0.5rem;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      color: var(--accent);
      text-decoration: none;
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
      padding: 0.5rem;
      border-radius: 0.375rem;
      transition: background 0.2s ease;
    }

    .back-link:hover {
      background: rgba(59, 130, 246, 0.08);
    }

    .post-list {
      list-style-type: none;
      margin: 0;
      padding: 0;
    }

    .post-item {
      padding: 0.4rem 0;
      border-radius: 0.375rem;
      transition: background 0.2s ease;
    }

    .post-item:hover {
      background: rgba(59, 130, 246, 0.06);
    }

    .post-link {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      text-decoration: none;
      color: var(--text-primary);
      padding: 0.375rem 0.5rem;
      border-radius: 0.375rem;
      transition: color 0.2s ease;
    }

    .post-link:hover {
      color: var(--accent);
    }

    .post-date {
      font-size: 0.85rem;
      color: var(--text-muted);
      min-width: 80px;
      flex-shrink: 0;
    }

    .post-title {
      font-size: 0.95rem;
      margin: 0;
    }

    .post-tags {
      display: flex;
      gap: 0.375rem;
      flex-wrap: wrap;
      flex-shrink: 0;
    }

    .post-tag {
      font-size: 0.7rem;
      color: var(--text-muted);
      padding: 0.125rem 0.375rem;
      background: var(--bg-secondary);
      border-radius: 0.25rem;
    }

    html.dark .page-title {
      color: var(--text-primary);
    }

    html.dark .page-title::before {
      background: linear-gradient(180deg, var(--accent-light), #a78bfa);
    }

    html.dark .page-subtitle {
      color: var(--text-muted);
    }

    html.dark .back-link {
      color: var(--accent-light);
    }

    html.dark .back-link:hover {
      background: rgba(96, 165, 250, 0.1);
    }

    html.dark .post-link {
      color: var(--text-primary);
      text-decoration: none;
    }

    html.dark .post-link:hover {
      color: var(--accent-light);
      text-decoration: none;
    }

    html.dark .post-item:hover {
      background: rgba(96, 165, 250, 0.08);
    }

    html.dark .post-date {
      color: var(--text-muted);
    }

    html.dark .post-tag {
      color: var(--text-muted);
      background: var(--bg-secondary);
    }
  </style>
</head>
<body>
  <Header />
  <main>
    <a href="/tags/" class="back-link">← Back to tags</a>
    <h1 class="page-title">#{tag}</h1>
    <p class="page-subtitle">{posts.length} posts</p>
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-item" key={post.id}>
          <a href={`/blog/${post.id}/`} class="post-link">
            <span class="post-date">{formatDate(post.data.pubDate)}</span>
            <h3 class="post-title">{post.data.title}</h3>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="post-tags">
                {post.data.tags.slice(0, 3).map((t) => (
                  <span class="post-tag">#{t}</span>
                ))}
                {post.data.tags.length > 3 && (
                  <span class="post-tag">...{post.data.tags.length - 3}</span>
                )}
              </div>
            )}
          </a>
        </li>
      ))}
    </ul>
  </main>
  <Footer />
</body>
</html>